	processor 6502

; --- Zero Page Variables ---
STAR_X	= $00	; current star screen X (byte column)
STAR_Y	= $01	; current star screen Y (pixel row)
HGRPTR	= $02	; pointer for HGR memory (lo, hi)
ROWTEMP	= $04	; temp for row calculation
STAR_IDX = $05	; current star index
SEED	= $06	; PRNG state
TEMP_HI	= $07	; scaling temp high byte
TEMP_LO	= $08	; scaling temp low byte
SHIP_X	= $09	; ship byte column (0-38)
SHIP_Y	= $0A	; ship top pixel row (0-186)
SHIP_ROW = $0B	; temp: current sprite row being drawn

; --- Soft Switches ---
TXTCLR	= $C050		; enable graphics
MIXCLR	= $C052		; full screen (no mixed text)
TXTPAGE2 = $C055	; display page 2
HIRES	= $C057		; enable hires
KBD	= $C000		; keyboard data (bit 7 = key available)
KBDSTRB	= $C010		; keyboard strobe (read to clear)
PADDL0	= $C064		; paddle 0 (X axis)
PADDL1	= $C065		; paddle 1 (Y axis)
PTRIG	= $C070		; paddle trigger

; --- Constants ---
HGRBASE	= $40		; HGR page 2 high byte
NUM_STARS = 42		; number of stars
CENTER_X = 20		; screen center byte column
CENTER_Y = 96		; screen center pixel row
SHIP_START_X = 18	; ship initial X
SHIP_START_Y = 150	; ship initial Y
SHIP_HEIGHT = 5		; ship sprite height in rows

	org $803

; ==============================
;         Data Tables
; ==============================
	jmp Start

ThirdOff
	.byte $28, $50

BitMasks
	.byte $01, $02, $04, $08, $10, $20, $40

ShipSprite
	.byte $08	; ...X...
	.byte $1C	; ..XXX..
	.byte $3E	; .XXXXX.
	.byte $14	; ..X.X..
	.byte $14	; ..X.X..

; --- Star state arrays (8.8 fixed-point offsets from center) ---
StarsDXL ds NUM_STARS	; X offset fractional part
StarsDXH ds NUM_STARS	; X offset integer part (signed, byte columns)
StarsDYL ds NUM_STARS	; Y offset fractional part
StarsDYH ds NUM_STARS	; Y offset integer part (signed, pixel rows)

; ==============================
;         Entry Point
; ==============================
Start SUBROUTINE
	sta TXTCLR
	sta MIXCLR
	sta TXTPAGE2
	sta HIRES

	lda #$A5
	sta SEED

	lda #SHIP_START_X
	sta SHIP_X
	lda #SHIP_START_Y
	sta SHIP_Y

	jsr ClearHGR
	jsr InitAllStars

; ==============================
;         Main Loop
; ==============================
MainLoop SUBROUTINE
	lda #0
	sta STAR_IDX
.starLoop
	jsr ProcessStar
	inc STAR_IDX
	lda STAR_IDX
	cmp #NUM_STARS
	bne .starLoop

	jsr EraseShip
	jsr ReadInput
	jsr DrawShip

	jmp MainLoop

; ==============================
;       Read Input
; ==============================
ReadInput SUBROUTINE
	; Check keyboard
	lda KBD
	bpl .noKey		; bpl .tryJoystick
	sta KBDSTRB
	cmp #$8B		; up arrow
	beq .up
	cmp #$8A		; down arrow
	beq .down
	cmp #$88		; left arrow
	beq .left
	cmp #$95		; right arrow
	beq .right
.noKey
	rts

.tryJoystick
	; Read paddle 0 (X axis)
	lda PTRIG
	ldy #0
.pdl0
	lda PADDL0
	bpl .pdl0Done
	iny
	bne .pdl0
.pdl0Done
	cpy #240		; no joystick connected
	bcs .readY
	cpy #80
	bcc .joyLeft
	cpy #176
	bcs .joyRight
	jmp .readY
.joyLeft
	lda SHIP_X
	beq .readY
	dec SHIP_X
	jmp .readY
.joyRight
	lda SHIP_X
	cmp #38
	bcs .readY
	inc SHIP_X
.readY
	; Read paddle 1 (Y axis)
	lda PTRIG
	ldy #0
.pdl1
	lda PADDL1
	bpl .pdl1Done
	iny
	bne .pdl1
.pdl1Done
	cpy #240
	bcs .done
	cpy #80
	bcc .up
	cpy #176
	bcs .down
	rts

.left
	lda SHIP_X
	beq .done
	dec SHIP_X
	rts
.right
	lda SHIP_X
	cmp #38
	bcs .done
	inc SHIP_X
	rts
.up
	lda SHIP_Y
	cmp #3
	bcc .done
	sec
	sbc #3
	sta SHIP_Y
	rts
.down
	lda SHIP_Y
	cmp #183
	bcs .done
	clc
	adc #3
	sta SHIP_Y
.done
	rts

; ==============================
;       Draw Ship
; ==============================
DrawShip SUBROUTINE
	lda #0
	sta SHIP_ROW
.loop
	lda SHIP_ROW
	clc
	adc SHIP_Y
	cmp #192
	bcs .skip
	jsr CalcRowAddr
	ldy SHIP_X
	ldx SHIP_ROW
	lda ShipSprite,x
	ora (HGRPTR),y
	sta (HGRPTR),y
.skip
	inc SHIP_ROW
	lda SHIP_ROW
	cmp #SHIP_HEIGHT
	bne .loop
	rts

; ==============================
;       Erase Ship
; ==============================
EraseShip SUBROUTINE
	lda #0
	sta SHIP_ROW
.loop
	lda SHIP_ROW
	clc
	adc SHIP_Y
	cmp #192
	bcs .skip
	jsr CalcRowAddr
	ldy SHIP_X
	ldx SHIP_ROW
	lda ShipSprite,x
	eor #$FF
	and (HGRPTR),y
	sta (HGRPTR),y
.skip
	inc SHIP_ROW
	lda SHIP_ROW
	cmp #SHIP_HEIGHT
	bne .loop
	rts

; ==============================
;       Process One Star
; ==============================
ProcessStar SUBROUTINE
	ldx STAR_IDX

	; --- Erase at old position ---
	lda StarsDXH,x
	clc
	adc #CENTER_X
	sta STAR_X
	cmp #40
	bcs .skipErase
	lda StarsDYH,x
	clc
	adc #CENTER_Y
	sta STAR_Y
	cmp #192
	bcs .skipErase
	jsr EraseStar
.skipErase

	; --- Scale DX by 17/16: DX += DX/16 ---
	ldx STAR_IDX
	lda StarsDXH,x
	sta TEMP_HI
	lda StarsDXL,x
	sta TEMP_LO
	; Arithmetic shift right 4 times (signed /16)
	lda TEMP_HI
	cmp #$80
	ror TEMP_HI
	ror TEMP_LO
	lda TEMP_HI
	cmp #$80
	ror TEMP_HI
	ror TEMP_LO
	lda TEMP_HI
	cmp #$80
	ror TEMP_HI
	ror TEMP_LO
	lda TEMP_HI
	cmp #$80
	ror TEMP_HI
	ror TEMP_LO
	; Add DX/16 to DX
	ldx STAR_IDX
	lda StarsDXL,x
	clc
	adc TEMP_LO
	sta StarsDXL,x
	lda StarsDXH,x
	adc TEMP_HI
	sta StarsDXH,x

	; --- Scale DY by 17/16: DY += DY/16 ---
	lda StarsDYH,x
	sta TEMP_HI
	lda StarsDYL,x
	sta TEMP_LO
	lda TEMP_HI
	cmp #$80
	ror TEMP_HI
	ror TEMP_LO
	lda TEMP_HI
	cmp #$80
	ror TEMP_HI
	ror TEMP_LO
	lda TEMP_HI
	cmp #$80
	ror TEMP_HI
	ror TEMP_LO
	lda TEMP_HI
	cmp #$80
	ror TEMP_HI
	ror TEMP_LO
	ldx STAR_IDX
	lda StarsDYL,x
	clc
	adc TEMP_LO
	sta StarsDYL,x
	lda StarsDYH,x
	adc TEMP_HI
	sta StarsDYH,x

	; --- Compute new screen position ---
	lda StarsDXH,x
	clc
	adc #CENTER_X
	sta STAR_X
	cmp #40
	bcs .respawn
	lda StarsDYH,x
	clc
	adc #CENTER_Y
	sta STAR_Y
	cmp #192
	bcs .respawn

	; --- Draw at new position ---
	jsr DrawStar
	rts

.respawn
	jsr RespawnStar
	ldx STAR_IDX
	lda StarsDXH,x
	clc
	adc #CENTER_X
	sta STAR_X
	lda StarsDYH,x
	clc
	adc #CENTER_Y
	sta STAR_Y
	jsr DrawStar
	rts

; ==============================
;     Initialize All Stars
; ==============================
; Spread stars across full screen by using wide DY range
InitAllStars SUBROUTINE
	lda #0
	sta STAR_IDX
.loop
	jsr InitStarWide
	inc STAR_IDX
	lda STAR_IDX
	cmp #NUM_STARS
	bne .loop
	rts

; ==============================
;   Init Star (wide spread)
; ==============================
; For initial distribution: DX +/-(1-18), DY +/-(1-90)
; Stars pre-spread across full screen
InitStarWide SUBROUTINE
	ldx STAR_IDX
	jsr Random
	sta StarsDXL,x
	jsr Random
	sta StarsDYL,x
	; DX_hi = +/-(1-18)
	jsr Random
	pha
	and #$0F
	clc
	adc #1		; 1-16
	sta StarsDXH,x
	pla
	bpl .dxPos
	lda #0
	sec
	sbc StarsDXH,x
	sta StarsDXH,x
.dxPos
	; DY_hi = +/-(1-90) -- full screen coverage
	jsr Random
	pha
	and #$3F
	clc
	adc #1		; 1-64
	; Add another random 0-26 for range 1-90
	sta TEMP_LO
	jsr Random
	and #$1F	; 0-31
	clc
	adc TEMP_LO
	; Clamp to 90 max
	cmp #91
	bcc .dyOk
	lda #90
.dyOk
	ldx STAR_IDX
	sta StarsDYH,x
	pla
	bpl .dyPos
	lda #0
	sec
	sbc StarsDYH,x
	sta StarsDYH,x
.dyPos
	rts

; ==============================
;   Respawn Star (near center)
; ==============================
; For respawn: small offsets so stars emerge from center
; DX +/-(1-4), DY +/-(5-20)
RespawnStar SUBROUTINE
	ldx STAR_IDX
	jsr Random
	sta StarsDXL,x
	jsr Random
	sta StarsDYL,x
	; DX_hi = +/-(1-4)
	jsr Random
	pha
	and #$03
	clc
	adc #1
	sta StarsDXH,x
	pla
	bpl .dxPos
	lda #0
	sec
	sbc StarsDXH,x
	sta StarsDXH,x
.dxPos
	; DY_hi = +/-(5-20)
	jsr Random
	pha
	and #$0F
	clc
	adc #5
	sta StarsDYH,x
	pla
	bpl .dyPos
	lda #0
	sec
	sbc StarsDYH,x
	sta StarsDYH,x
.dyPos
	rts

; ==============================
;      PRNG (Galois LFSR)
; ==============================
Random SUBROUTINE
	lda SEED
	lsr
	bcc .noTap
	eor #$B4
.noTap
	sta SEED
	rts

; ==============================
;        Draw Star Pixel
; ==============================
DrawStar SUBROUTINE
	ldx STAR_IDX
	lda StarsDXL,x
	lsr
	lsr
	lsr
	lsr
	lsr
	cmp #7
	bcc .bitOk
	lda #6
.bitOk
	tax
	lda BitMasks,x
	pha
	lda STAR_Y
	jsr CalcRowAddr
	ldy STAR_X
	pla
	ora (HGRPTR),y
	sta (HGRPTR),y
	rts

; ==============================
;       Erase Star Pixel
; ==============================
EraseStar SUBROUTINE
	ldx STAR_IDX
	lda StarsDXL,x
	lsr
	lsr
	lsr
	lsr
	lsr
	cmp #7
	bcc .bitOk
	lda #6
.bitOk
	tax
	lda BitMasks,x
	eor #$FF
	pha
	lda STAR_Y
	jsr CalcRowAddr
	ldy STAR_X
	pla
	and (HGRPTR),y
	sta (HGRPTR),y
	rts

; ==============================
;      Clear HGR Page 2
; ==============================
ClearHGR SUBROUTINE
	lda #0
	sta HGRPTR
	lda #HGRBASE
	sta HGRPTR+1
	tay
	lda #0
.loop
	sta (HGRPTR),y
	iny
	bne .loop
	inc HGRPTR+1
	ldx HGRPTR+1
	cpx #HGRBASE+$20
	bne .loop
	rts

; ==============================
;    Calculate HGR Row Address
; ==============================
CalcRowAddr SUBROUTINE
	sta ROWTEMP

	and #$07
	asl
	asl
	adc #HGRBASE
	sta HGRPTR+1

	lda ROWTEMP
	lsr
	lsr
	lsr
	lsr
	and #$03
	clc
	adc HGRPTR+1
	sta HGRPTR+1

	lda ROWTEMP
	and #$08
	beq .noBit3
	lda #$80
.noBit3
	sta HGRPTR

	lda ROWTEMP
	lsr
	lsr
	lsr
	lsr
	lsr
	lsr
	beq .done
	tax
	lda ThirdOff-1,x
	clc
	adc HGRPTR
	sta HGRPTR
.done
	rts
