; --- "GAME OVER" bitmap (5 rows x 10 cols, bits reversed for HGR) ---
;        G         A         M         E         _         O         V         E         R        (pad)
GameOverBmp
	.byte %00011110,%00011110,%00101010,%00111110,%00000000,%00011110,%00100010,%00111110,%00011110,%00000000
	.byte %00000010,%00010010,%00110110,%00000010,%00000000,%00010010,%00100010,%00000010,%00010010,%00000000
	.byte %00011010,%00011110,%00100010,%00011110,%00000000,%00010010,%00010100,%00011110,%00011110,%00000000
